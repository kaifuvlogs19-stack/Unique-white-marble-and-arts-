<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Unique White Marble & Arts</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">

<style>

/* ---------------- GENERAL ---------------- */

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:Poppins;
background:#0b0b0b;
color:white;
overflow-x:hidden;
}

h1,h2,h3{
font-family:'Playfair Display', serif;
letter-spacing:1px;
}

section{
padding:80px 8%;
}

.gold{
color:#d4af37;
}

/* ---------------- NAVBAR ---------------- */

nav{
position:fixed;
width:100%;
top:0;
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 8%;
background:rgba(0,0,0,.6);
backdrop-filter:blur(8px);
z-index:999;
}

.logo{
font-size:22px;
font-weight:bold;
color:#d4af37;
}

.menu{
display:flex;
gap:25px;
}

.menu a{
text-decoration:none;
color:white;
font-size:15px;
}

.menu a:hover{
color:#d4af37;
}

.hamburger{
display:none;
font-size:24px;
cursor:pointer;
}

/* ---------------- HERO VIDEO ---------------- */

.hero{
height:100vh;
position:relative;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
}

.hero video{
position:absolute;
width:100%;
height:100%;
object-fit:cover;
z-index:-1;
}

.hero::after{
content:"";
position:absolute;
width:100%;
height:100%;
background:rgba(0,0,0,.6);
z-index:-1;
}

.hero h1{
font-size:52px;
margin-bottom:15px;
}

.btn{
background:#d4af37;
padding:14px 32px;
border:none;
color:black;
cursor:pointer;
border-radius:6px;
font-weight:500;
transition:.3s;
}

.btn:hover{
transform:scale(1.05);
background:white;
}

/* ---------------- ABOUT ---------------- */

.about{
text-align:center;
max-width:900px;
margin:auto;
line-height:1.7;
opacity:0;
transform:translateY(40px);
transition:.8s;
}

.about.show{
opacity:1;
transform:translateY(0);
}

/* ---------------- PRODUCTS ---------------- */

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:30px;
}

.card{
background:#111;
border-radius:12px;
overflow:hidden;
transition:.4s;
position:relative;
}

.card img{
width:100%;
height:280px;
object-fit:cover;
}

.card:hover{
transform:translateY(-10px) scale(1.02);
box-shadow:0 0 25px rgba(212,175,55,.3);
}

.card-content{
padding:20px;
}

.card h3{
margin-bottom:10px;
}

.whatsapp-btn{
display:inline-block;
margin-top:10px;
background:#d4af37;
color:black;
padding:10px 18px;
text-decoration:none;
border-radius:5px;
font-size:14px;
}

/* ---------------- FOOTER ---------------- */

footer{
background:#050505;
text-align:center;
padding:40px 8%;
}

.social{
margin-top:15px;
}

.social a{
margin:0 10px;
color:#d4af37;
font-size:18px;
text-decoration:none;
}

/* ---------------- MOBILE ---------------- */

@media(max-width:768px){

.menu{
position:absolute;
top:70px;
right:0;
background:black;
flex-direction:column;
width:200px;
padding:20px;
display:none;
}

.menu.show{
display:flex;
animation:fade .4s;
}

.hamburger{
display:block;
}

.hero h1{
font-size:34px;
}

}

@keyframes fade{
from{opacity:0; transform:translateY(-10px);}
to{opacity:1;}
}

</style>

</head>

<body>

<!-- NAVBAR -->

<nav>

<div class="logo">Unique Marble</div>

<div class="hamburger" onclick="toggleMenu()">☰</div>

<div class="menu" id="menu">

<a href="#">Home</a>

<a href="#mandir">Mandir</a>

<a href="#fountain">Fountain</a>

<a href="#about">About</a>

</div>

</nav>


<!-- HERO -->

<section class="hero">

<video autoplay muted loop>

<source src="hero-video.mp4" type="video/mp4">

</video>

<div>

<h1 class="gold">Luxury Marble Art</h1>

<p>Premium Handcrafted Mandir & Fountain</p>

<br>

<button class="btn">Explore Collection</button>

</div>

</section>


<!-- ABOUT -->

<section id="about">

<div class="about">

<h2 class="gold">About Us</h2>

<p>

Unique White Marble & Arts creates premium handcrafted marble temples and fountains designed with elegance and luxury finish.

</p>

</div>

</section>


<!-- MANDIR SECTION -->

<section id="mandir">

<h2 class="gold">Marble Mandir Collection</h2>

<br>

<div class="products">

<div class="card">

<img src="mandir.jpg" alt="White Marble Mandir">

<div class="card-content">

<h3>Premium Mandir</h3>

<a class="whatsapp-btn" href="#">WhatsApp</a>

</div>

</div>

</div>

</section>


<!-- FOUNTAIN SECTION -->

<section id="fountain">

<h2 class="gold">Marble Fountain Collection</h2>

<br>

<div class="products">

<div class="card">

<img src="fountain.jpg" alt="Luxury Marble Fountain">

<div class="card-content">

<h3>Luxury Fountain</h3>

<a class="whatsapp-btn" href="#">WhatsApp</a>

</div>

</div>

</div>

</section>


<!-- FOOTER -->

<footer>

<h3 class="gold">Unique White Marble & Arts</h3>

<div class="social">

<a href="https://www.instagram.com/unique_white_marbel_and_art">Instagram</a>

<a href="https://youtube.com/@unique_white_marbel.?si=DozGuyNgezYEiIk6">YouTube</a>

</div>

<p>© 2026 All Rights Reserved</p>

</footer>


<script>

/* menu */

function toggleMenu(){
document.getElementById("menu").classList.toggle("show");
}


/* scroll animation */

const observer = new IntersectionObserver(entries=>{
entries.forEach(entry=>{
if(entry.isIntersecting){
entry.target.classList.add("show")
}
})
})

document.querySelectorAll(".about").forEach(el=>{
observer.observe(el)
})

</script>

</body>
</html>
