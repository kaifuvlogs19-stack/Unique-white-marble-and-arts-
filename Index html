<!-- =========================
     UNIQUE WHITE MARBLE & ARTS
     Premium Luxury Landing Page
     Single file: HTML + CSS + JS
========================= -->

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Unique White Marble & Arts — premium marble fountains and home mandir handcrafted in Rajasthan." />
  <title>Unique White Marble & Arts</title>

  <style>
    /* =========================
       THEME TOKENS
    ========================== */
    :root{
      --bg0:#07070a;
      --bg1:#0d0d13;
      --card:#11111a;
      --card2:#0f0f16;
      --text:#f3f4f6;
      --muted:#b9bbc7;
      --gold:#d6b35a;
      --gold2:#f0d389;
      --line: rgba(214,179,90,.25);
      --shadow: 0 18px 60px rgba(0,0,0,.55);
      --shadow2: 0 10px 30px rgba(214,179,90,.12);
      --radius: 18px;
      --radius2: 26px;
      --max: 1200px;
      --ease: cubic-bezier(.2,.8,.2,1);
    }

    *{ box-sizing:border-box; }
    html, body{ height:100%; }
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      background: radial-gradient(1200px 600px at 20% -10%, rgba(214,179,90,.10), transparent 60%),
                  radial-gradient(900px 500px at 95% 10%, rgba(214,179,90,.08), transparent 50%),
                  linear-gradient(180deg, var(--bg0), var(--bg1));
      color:var(--text);
      overflow-x:hidden;
    }

    a{ color:inherit; text-decoration:none; }
    img{ max-width:100%; display:block; }
    button, input, select, textarea{
      font:inherit;
      outline:none;
    }

    /* =========================
       UTILS
    ========================== */
    .container{ width:min(var(--max), calc(100% - 40px)); margin:0 auto; }
    .section{ padding: 70px 0; position:relative; }
    .section.compact{ padding: 48px 0; }

    .gold-text{
      color: var(--gold2);
      text-shadow: 0 0 24px rgba(214,179,90,.2);
    }

    .section-title{
      display:flex; align-items:flex-end; justify-content:space-between; gap:18px;
      margin-bottom: 26px;
    }
    .section-title h2{
      margin:0;
      font-size: clamp(22px, 2.2vw, 34px);
      letter-spacing:.2px;
      line-height:1.15;
    }
    .section-title p{
      margin:0;
      color:var(--muted);
      max-width: 560px;
      line-height:1.5;
      font-size: 14.5px;
    }

    /* =========================
       HEADER
    ========================== */
    header{
      position: sticky;
      top:0;
      z-index: 999;
      backdrop-filter: blur(12px);
      background: rgba(7,7,10,.55);
      border-bottom: 1px solid rgba(214,179,90,.10);
    }
    .nav-wrap{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding: 14px 0;
      gap: 16px;
    }

    .brand{
      display:flex; align-items:center; gap:12px;
      min-width: 230px;
    }
    .brand .logo{
      width: 40px; height:40px;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(214,179,90,.25), rgba(214,179,90,.06));
      border: 1px solid rgba(214,179,90,.28);
      display:grid; place-items:center;
      box-shadow: var(--shadow2);
      overflow:hidden;
    }
    .brand .logo img{ width:100%; height:100%; object-fit:cover; }
    .brand .name{
      display:flex; flex-direction:column; gap:2px;
    }
    .brand .name strong{
      font-size: 14px;
      letter-spacing:.8px;
      text-transform: uppercase;
      line-height:1.2;
    }
    .brand .name span{
      font-size: 12.5px;
      color: var(--muted);
      letter-spacing:.2px;
    }

    nav{
      display:flex;
      align-items:center;
      gap: 10px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .nav-links{
      display:flex;
      gap: 10px;
      align-items:center;
    }

    .nav-links a{
      padding: 10px 12px;
      border-radius: 12px;
      color: var(--muted);
      border: 1px solid transparent;
      transition: transform .2s var(--ease), border-color .2s var(--ease), color .2s var(--ease), background .2s var(--ease);
      white-space:nowrap;
    }
    .nav-links a:hover{
      color: var(--text);
      border-color: rgba(214,179,90,.35);
      background: rgba(214,179,90,.08);
      transform: translateY(-1px);
    }

    .nav-cta{
      display:flex;
      gap: 10px;
      align-items:center;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap: 10px;
      padding: 11px 14px;
      border-radius: 14px;
      border:1px solid rgba(214,179,90,.35);
      background: linear-gradient(135deg, rgba(214,179,90,.18), rgba(214,179,90,.05));
      color: var(--text);
      cursor:pointer;
      transition: transform .22s var(--ease), box-shadow .22s var(--ease), border-color .22s var(--ease), background .22s var(--ease);
      box-shadow: 0 14px 34px rgba(0,0,0,.35);
    }
    .btn:hover{
      transform: translateY(-2px);
      border-color: rgba(240,211,137,.65);
      box-shadow: 0 18px 60px rgba(214,179,90,.16);
    }
    .btn:active{ transform: translateY(0px) scale(.99); }

    .btn.gold{
      background: linear-gradient(135deg, rgba(214,179,90,.92), rgba(214,179,90,.18));
      border-color: rgba(214,179,90,.7);
      color: #151515;
      font-weight: 700;
    }

    .btn.ghost{
      background: rgba(255,255,255,.03);
      border-color: rgba(214,179,90,.22);
      color: var(--text);
    }

    .icon{
      width:18px; height:18px; display:inline-block;
    }

    /* Hamburger */
    .hamburger{
      display:none;
      width:44px; height:44px;
      border-radius: 14px;
      border: 1px solid rgba(214,179,90,.28);
      background: rgba(255,255,255,.03);
      cursor:pointer;
      transition: transform .2s var(--ease), border-color .2s var(--ease);
    }
    .hamburger:hover{
      transform: translateY(-1px);
      border-color: rgba(240,211,137,.55);
    }
    .hamburger .bars{
      width:18px; height:14px; margin:0 auto; position:relative;
    }
    .hamburger .bars span{
      position:absolute; left:0; right:0;
      height:2px; background: var(--gold2);
      border-radius: 99px;
      transition: transform .28s var(--ease), top .28s var(--ease), opacity .2s var(--ease);
    }
    .hamburger .bars span:nth-child(1){ top:0; }
    .hamburger .bars span:nth-child(2){ top:6px; opacity:1; }
    .hamburger .bars span:nth-child(3){ top:12px; }

    /* Mobile menu panel */
    .mobile-panel{
      display:none;
      overflow:hidden;
      border-top: 1px solid rgba(214,179,90,.12);
      background: rgba(7,7,10,.78);
    }
    .mobile-panel.open{ display:block; }
    .mobile-panel-inner{
      padding: 14px 0 18px;
    }
    .mobile-links{
      display:flex;
      flex-direction:column;
      gap: 8px;
    }
    .mobile-links a{
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid rgba(214,179,90,.18);
      background: rgba(214,179,90,.06);
      color: var(--text);
    }

    /* =========================
       HERO
    ========================== */
    .hero{
      padding: 42px 0 28px;
    }
    .hero-grid{
      display:grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 26px;
      align-items:stretch;
    }

    .hero-media{
      border-radius: var(--radius2);
      overflow:hidden;
      border: 1px solid rgba(214,179,90,.22);
      background: rgba(255,255,255,.02);
      box-shadow: var(--shadow);
      min-height: 420px;
      position:relative;
    }

    .hero-media video{
      width:100%; height:100%;
      object-fit: cover;
      transform: scale(1.02);
      filter: saturate(1.05) contrast(1.03);
    }
    .hero-media::after{
      content:"";
      position:absolute; inset:0;
      background:
        linear-gradient(90deg, rgba(0,0,0,.55), rgba(0,0,0,.05) 55%),
        linear-gradient(180deg, rgba(0,0,0,.20), rgba(0,0,0,.62));
      pointer-events:none;
    }

    .hero-content{
      border-radius: var(--radius2);
      border: 1px solid rgba(214,179,90,.18);
      background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01));
      box-shadow: 0 10px 38px rgba(0,0,0,.35);
      padding: 26px;
      display:flex; flex-direction:column;
      justify-content:space-between;
      gap: 18px;
      min-height: 420px;
    }

    .hero-kicker{
      display:flex; align-items:center; gap:10px; flex-wrap:wrap;
      color: var(--muted);
      letter-spacing:.2px;
      font-size: 13.5px;
      margin-top: 4px;
    }

    .pill{
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(214,179,90,.22);
      background: rgba(214,179,90,.08);
      color: var(--gold2);
      font-weight:700;
      font-size: 12.5px;
    }

    .hero-content h1{
      margin: 10px 0 10px;
      font-size: clamp(28px, 3vw, 44px);
      line-height: 1.05;
      letter-spacing: .2px;
    }
    .hero-content p{
      margin:0;
      color: var(--muted);
      line-height:1.6;
      font-size: 14.8px;
    }

    .hero-actions{
      display:flex;
      gap: 12px;
      flex-wrap:wrap;
      align-items:center;
      margin-top: 12px;
    }

    .stats{
      display:grid;
      grid-template-columns: repeat(4, minmax(0,1fr));
      gap: 12px;
      margin-top: 16px;
    }
    .stat{
      border-radius: 16px;
      border: 1px solid rgba(214,179,90,.16);
      background: rgba(255,255,255,.02);
      padding: 12px 12px;
    }
    .stat strong{
      font-size: 18px;
      letter-spacing:.2px;
      display:block;
    }
    .stat span{
      color: var(--muted);
      font-size: 12.5px;
      display:block;
      margin-top: 4px;
      line-height:1.3;
    }

    /* =========================
       FILTER TABS
    ========================== */
    .tabs{
      display:flex;
      gap: 10px;
      flex-wrap:wrap;
      margin-bottom: 18px;
    }
    .tab{
      padding: 10px 12px;
      border-radius: 14px;
      border:1px solid rgba(214,179,90,.18);
      background: rgba(255,255,255,.02);
      color: var(--muted);
      cursor:pointer;
      transition: transform .22s var(--ease), border-color .22s var(--ease), background .22s var(--ease), color .22s var(--ease);
      user-select:none;
    }
    .tab:hover{
      transform: translateY(-2px);
      border-color: rgba(240,211,137,.55);
      color: var(--text);
    }
    .tab.active{
      background: rgba(214,179,90,.14);
      border-color: rgba(240,211,137,.65);
      color: var(--gold2);
      font-weight: 700;
    }

    /* =========================
       PRODUCT CARDS (Luxury)
    ========================== */
    .grid{
      display:grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 18px;
    }
    .card{
      border-radius: var(--radius2);
      border: 1px solid rgba(214,179,90,.18);
      background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01));
      box-shadow: 0 12px 40px rgba(0,0,0,.28);
      overflow:hidden;
      position:relative;
      transform: translateZ(0);
      transition: transform .28s var(--ease), border-color .28s var(--ease), box-shadow .28s var(--ease);
      min-height: 420px;
      display:flex;
      flex-direction:column;
    }

    .card:hover{
      transform: translateY(-8px);
      border-color: rgba(240,211,137,.6);
      box-shadow: 0 22px 70px rgba(0,0,0,.55);
    }

    .card-media{
      height: 205px;
      background: rgba(214,179,90,.06);
      position:relative;
    }
    .card-media img{
      width:100%; height:100%;
      object-fit:cover;
      filter: saturate(1.05);
    }
    .card-media::after{
      content:"";
      position:absolute; inset:0;
      background: linear-gradient(180deg, rgba(0,0,0,.05), rgba(0,0,0,.55));
      pointer-events:none;
    }

    .badge-row{
      position:absolute; left:14px; top:14px;
      display:flex; gap: 8px; flex-wrap:wrap;
      z-index:2;
    }
    .badge{
      padding: 8px 10px;
      border-radius: 999px;
      background: rgba(7,7,10,.55);
      border:1px solid rgba(214,179,90,.24);
      color: var(--gold2);
      font-size: 12.5px;
      font-weight: 700;
      backdrop-filter: blur(8px);
    }

    .card-body{
      padding: 16px 16px 14px;
      display:flex; flex-direction:column; gap: 10px;
      flex: 1;
    }
    .card-body h3{
      margin:0;
      font-size: 17px;
      letter-spacing:.2px;
      line-height:1.25;
    }
    .card-body p{
      margin:0;
      color: var(--muted);
      line-height:1.6;
      font-size: 13.8px;
      min-height: 44px;
    }
    .price{
      display:flex; align-items:baseline; justify-content:space-between; gap: 10px;
      margin-top:auto;
    }
    .price strong{
      font-size: 18px;
      color: var(--gold2);
    }
    .price span{
      color: var(--muted);
      font-size: 12.5px;
    }

    .card-actions{
      padding: 14px 16px 16px;
      display:flex; gap: 10px; align-items:center; justify-content:space-between;
      border-top: 1px solid rgba(214,179,90,.12);
      background: rgba(255,255,255,.015);
    }

    .mini-btn{
      flex:1;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(214,179,90,.24);
      background: rgba(214,179,90,.08);
      color: var(--text);
      cursor:pointer;
      transition: transform .2s var(--ease), border-color .2s var(--ease), background .2s var(--ease);
      display:inline-flex; align-items:center; justify-content:center; gap: 8px;
      font-weight: 700;
      min-height: 42px;
    }
    .mini-btn:hover{
      transform: translateY(-2px);
      border-color: rgba(240,211,137,.6);
      background: rgba(214,179,90,.14);
    }
    .mini-btn.primary{
      background: linear-gradient(135deg, rgba(214,179,90,.92), rgba(214,179,90,.18));
      border-color: rgba(214,179,90,.75);
      color: #151515;
    }
    .mini-btn.whatsapp{
      background: rgba(0,0,0,.2);
      border-color: rgba(0,0,0,.2);
    }
    .mini-btn.whatsapp .wa{
      width:18px; height:18px;
      display:inline-grid; place-items:center;
      border-radius: 8px;
      background: rgba(214,179,90,.18);
      border: 1px solid rgba(214,179,90,.3);
    }

    /* =========================
       ABOUT US
    ========================== */
    .about-grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      align-items:stretch;
    }
    .about-card{
      border-radius: var(--radius2);
      border: 1px solid rgba(214,179,90,.18);
      background: rgba(255,255,255,.02);
      padding: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,.28);
      position:relative;
      overflow:hidden;
    }
    .about-card::after{
      content:"";
      position:absolute; inset:-80px -60px auto auto;
      width:240px; height:240px;
      background: radial-gradient(circle at 30% 30%, rgba(214,179,90,.25), transparent 60%);
      transform: rotate(20deg);
      pointer-events:none;
    }
    .about-card h3{
      margin:0 0 10px;
      font-size: 18px;
      letter-spacing:.2px;
    }
    .about-card p{
      margin:0;
      color: var(--muted);
      line-height:1.7;
      font-size: 14.5px;
    }
    .about-points{
      margin-top: 14px;
      display:grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .point{
      display:flex; gap: 12px; align-items:flex-start;
      padding: 12px 12px;
      border-radius: 16px;
      border: 1px solid rgba(214,179,90,.14);
      background: rgba(214,179,90,.05);
    }
    .point .dot{
      width: 12px; height:12px;
      border-radius: 50%;
      background: var(--gold2);
      box-shadow: 0 0 0 4px rgba(214,179,90,.15);
      margin-top: 4px;
      flex: 0 0 auto;
    }
    .point strong{
      display:block;
      font-size: 14.2px;
      letter-spacing:.2px;
      margin-bottom: 3px;
    }
    .point span{
      color: var(--muted);
      font-size: 13.5px;
      line-height:1.55;
      display:block;
    }

    /* =========================
       FOOTER
    ========================== */
    footer{
      border-top: 1px solid rgba(214,179,90,.12);
      padding: 34px 0 28px;
      background: rgba(0,0,0,.10);
    }
    .footer-grid{
      display:grid;
      grid-template-columns: 1.2fr 1fr 1fr;
      gap: 18px;
      align-items:start;
    }
    .footer-brand{
      display:flex; flex-direction:column; gap: 12px;
    }
    .footer-brand .brand-row{
      display:flex; align-items:center; gap:12px;
    }
    .footer-brand p{
      margin:0;
      color: var(--muted);
      line-height:1.7;
      font-size: 14px;
    }
    .footer-col h4{
      margin: 0 0 10px;
      color: var(--gold2);
      letter-spacing:.3px;
      font-size: 14.5px;
      text-transform: uppercase;
    }
    .footer-links{
      display:flex; flex-direction:column; gap: 8px;
    }
    .footer-links a{
      color: var(--muted);
      border-radius: 12px;
      padding: 10px 12px;
      border: 1px solid transparent;
      transition: background .2s var(--ease), border-color .2s var(--ease), color .2s var(--ease), transform .2s var(--ease);
    }
    .footer-links a:hover{
      color: var(--text);
      border-color: rgba(214,179,90,.3);
      background: rgba(214,179,90,.08);
      transform: translateY(-2px);
    }

    .social-row{
      display:flex; gap: 10px; flex-wrap:wrap;
      margin-top: 8px;
    }
    .social{
      display:inline-flex; align-items:center; gap: 10px;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(214,179,90,.22);
      background: rgba(255,255,255,.02);
      color: var(--text);
      transition: transform .22s var(--ease), border-color .22s var(--ease), background .22s var(--ease);
      min-height: 42px;
      font-weight: 700;
      font-size: 13.5px;
    }
    .social:hover{
      transform: translateY(-2px);
      border-color: rgba(240,211,137,.6);
      background: rgba(214,179,90,.10);
    }

    .copyright{
      margin-top: 18px;
      color: var(--muted);
      font-size: 12.8px;
      border-top: 1px solid rgba(214,179,90,.10);
      padding-top: 16px;
      display:flex; justify-content:space-between; gap: 12px; flex-wrap:wrap;
    }

    /* =========================
       SCROLL ANIMATIONS
    ========================== */
    .reveal{
      opacity:0;
      transform: translateY(14px);
      transition: opacity .7s var(--ease), transform .7s var(--ease);
      will-change: transform, opacity;
    }
    .reveal.in{
      opacity:1;
      transform: translateY(0);
    }

    /* =========================
       TOGGLE OPTION (Fountain/Mandir)
    ========================== */
    .mode-bar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid rgba(214,179,90,.18);
      background: rgba(255,255,255,.02);
      margin: 10px 0 22px;
      flex-wrap:wrap;
    }
    .mode-bar .left{
      display:flex; flex-direction:column; gap: 6px;
    }
    .mode-bar .left strong{
      font-size: 14.5px;
      letter-spacing:.2px;
    }
    .mode-bar .left span{
      color: var(--muted);
      font-size: 13.5px;
      line-height:1.4;
    }
    .mode-actions{
      display:flex; gap: 10px; flex-wrap:wrap;
      align-items:center;
    }
    .seg{
      display:flex; border-radius: 16px;
      border: 1px solid rgba(214,179,90,.22);
      overflow:hidden;
      background: rgba(255,255,255,.02);
    }
    .seg button{
      border:0;
      background: transparent;
      color: var(--muted);
      padding: 10px 12px;
      cursor:pointer;
      font-weight: 800;
      letter-spacing:.2px;
      transition: background .2s var(--ease), color .2s var(--ease);
    }
    .seg button.active{
      background: rgba(214,179,90,.14);
      color: var(--gold2);
    }

    /* =========================
       FORMS / CART STUB (KEEP SAFE)
    ========================== */
    /* You did not
